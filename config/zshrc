SOLUK_BASE_DIR="$(cat ~/.solukos/install_path 2>/dev/null)"
[ -z "$SOLUK_BASE_DIR" ] && SOLUK_BASE_DIR="$HOME/SolukOS"

clear

echo ""
bash "$SOLUK_BASE_DIR/scripts/lib/print_banner.sh" "$SOLUK_BASE_DIR"
echo ""
printf '\033[90m[ \033[0m\033[1m\033[96mSolukOS\033[0m\033[90m ] Terminal initialized.\033[0m\n'
echo ""

# Show a notice if a previous background check found a newer version
# (reads a local cache only, no network call here - stays fast).
if [ -f ~/.solukos/update_check ]; then
    bash -c 'source "$1/scripts/lib/ui.sh"; source "$1/scripts/lib/update_check.sh"; soluk_print_update_notice; echo ""' _ "$SOLUK_BASE_DIR"
fi

# Kick off a background version check for next time (throttled to once
# every 24h internally, so this is a no-op most days).
( bash "$SOLUK_BASE_DIR/scripts/lib/update_check.sh" __bg_check "$SOLUK_BASE_DIR" >/dev/null 2>&1 & ) 2>/dev/null

PROMPT='%F{8}┌──(%F{6}Soluk%F{8}㉿%F{6}Termux%F{8})-[%F{7}%~%F{8}]
└─$ %f'

alias update='pkg update && pkg upgrade'

# eza (modern ls) - falls back to classic ls/ls -la if not installed
if command -v eza >/dev/null 2>&1; then
    alias ls='eza --icons'
    alias ll='eza -la --icons'
    alias lt='eza --tree --icons'
else
    alias ll='ls -la'
fi

# bat (modern cat) - falls back to classic cat if not installed
if command -v bat >/dev/null 2>&1; then
    alias cat='bat --paging=never'
fi

# zoxide (smart cd, adds the `z` command) - only if installed
if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init zsh)"
fi

# fzf shell integration: CTRL+R history search, CTRL+T file search, ALT+C cd
[ -f "$PREFIX/share/fzf/key-bindings.zsh" ] && source "$PREFIX/share/fzf/key-bindings.zsh"
[ -f "$PREFIX/share/fzf/completion.zsh" ] && source "$PREFIX/share/fzf/completion.zsh"

# zsh's own completion system - needed for tab-completion (e.g. `soluk <TAB>`)
# -u skips the "insecure directories" prompt, which Android's permission
# model triggers constantly and would otherwise nag on every shell start.
autoload -Uz compinit
compinit -u

[ -f "$SOLUK_BASE_DIR/scripts/lib/completion.zsh" ] && source "$SOLUK_BASE_DIR/scripts/lib/completion.zsh"

# SolukOS zsh plugins (dosya yoksa sessizce atlar, hata vermez)
# zsh-syntax-highlighting must stay last for correct highlighting.
[ -f ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh ] && source ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh
[ -f ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && source ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
