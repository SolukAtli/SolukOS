#!/data/data/com.termux/files/usr/bin/bash

BASE_DIR="$(cat ~/.solukos/install_path 2>/dev/null)"

if [ -z "$BASE_DIR" ]; then
    echo "SolukOS installation path not found."
    exit 1
fi

source "$BASE_DIR/scripts/lib/ui.sh"

if [ "$1" = "version" ]; then
    VERSION_STR=$(cat "$BASE_DIR/VERSION" 2>/dev/null)
    [ -z "$VERSION_STR" ] && VERSION_STR="unknown"
    echo "SolukOS v$VERSION_STR"
    exit 0
fi

if [ "$1" = "help" ]; then
    echo "=============================="
    echo "       SolukOS Help"
    echo "=============================="
    echo ""
    echo "System:"
    echo "  soluk version"
    echo "  soluk doctor"
    echo "  soluk reload"
    echo "  soluk fetch"
    echo "  soluk help"
    echo ""
    echo "Packages:"
    echo "  soluk pkg list"
    echo "  soluk pkg search <name>"
    echo "  soluk pkg info <name>"
    echo "  soluk pkg install <name>"
    echo "  soluk pkg remove <name>"
    echo ""
    exit 0
fi

if [ "$1" = "doctor" ]; then
    echo "=== SolukOS Doctor ==="
    [ -d "$BASE_DIR" ] && soluk_ok "SolukOS directory" || soluk_fail "SolukOS directory"
    [ -f "$BASE_DIR/packages/database.txt" ] && soluk_ok "Package database" || soluk_fail "Package database"
    [ -f "$BASE_DIR/scripts/package/package_manager.sh" ] && soluk_ok "Package Manager" || soluk_fail "Package Manager"
    [ -f "$BASE_DIR/scripts/lib/ui.sh" ] && soluk_ok "UI library" || soluk_fail "UI library"
    command -v fzf >/dev/null 2>&1 && soluk_ok "fzf (modern menu)" || soluk_fail "fzf (modern menu) - pkg install fzf"
    command -v zoxide >/dev/null 2>&1 && soluk_ok "zoxide" || soluk_fail "zoxide - pkg install zoxide"
    command -v bat >/dev/null 2>&1 && soluk_ok "bat" || soluk_fail "bat - pkg install bat"
    command -v eza >/dev/null 2>&1 && soluk_ok "eza" || soluk_fail "eza - pkg install eza"
    [ -f ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh ] && soluk_ok "zsh-autosuggestions" || soluk_fail "zsh-autosuggestions - soluk update ile kurulur"
    [ -f ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && soluk_ok "zsh-syntax-highlighting" || soluk_fail "zsh-syntax-highlighting - soluk update ile kurulur"
    exit 0
fi

if [ "$1" = "reload" ]; then
    exec zsh
fi

if [ "$1" = "fetch" ]; then
    clear
    soluk_banner "$BASE_DIR"

    VERSION_STR=$(cat "$BASE_DIR/VERSION" 2>/dev/null)
    [ -z "$VERSION_STR" ] && VERSION_STR="unknown"

    UPTIME_STR=$(awk '{printf "%dh %dm", ($1/3600), ((($1)%3600)/60)}' /proc/uptime 2>/dev/null)
    [ -z "$UPTIME_STR" ] && UPTIME_STR="unknown"

    STORAGE_STR=$(df -h "$HOME" 2>/dev/null | awk 'NR==2{print $3" / "$2" used"}')
    [ -z "$STORAGE_STR" ] && STORAGE_STR="unknown"

    PKG_COUNT=$(grep -c '|' "$BASE_DIR/packages/database.txt" 2>/dev/null)
    [ -z "$PKG_COUNT" ] && PKG_COUNT=0

    row()
    {
        printf "  ${SOLUK_BOLD}${SOLUK_BCYAN}%-9s${SOLUK_RESET} %s\n" "$1" "$2"
    }

    row "OS"       "SolukOS v$VERSION_STR"
    row "Host"     "Termux (Android)"
    row "Kernel"   "$(uname -r 2>/dev/null)"
    row "Shell"    "${SHELL##*/}"
    row "Uptime"   "$UPTIME_STR"
    row "Storage"  "$STORAGE_STR"
    row "Packages" "$PKG_COUNT (soluk db)"
    echo ""
    exit 0
fi

if [ "$1" = "pkg" ]; then

DB_FILE="$BASE_DIR/packages/database.txt"

case "$2" in

list)
    cat "$DB_FILE"
    exit 0
    ;;

search)
    grep -i "$3" "$DB_FILE"
    exit 0
    ;;

info)
    INFO=$(grep "^$3|" "$DB_FILE")
    [ -z "$INFO" ] && echo "Package not found" && exit 1
    IFS="|" read -r NAME CATEGORY TYPE STATUS <<< "$INFO"
    echo "Name: $NAME"
    echo "Category: $CATEGORY"
    echo "Type: $TYPE"
    echo "Status: $STATUS"
    exit 0
    ;;

install)
    INFO=$(grep "^$3|" "$DB_FILE")
    [ -z "$INFO" ] && echo "Package not found" && exit 1
    IFS="|" read -r NAME CATEGORY TYPE STATUS <<< "$INFO"

    if [ "$TYPE" = "native" ]; then
        pkg install "$NAME" -y
    elif [ "$TYPE" = "plugin" ]; then
        echo "Plugin installer coming soon"
    else
        echo "Manual install required"
    fi
    exit 0
    ;;

remove)
    INFO=$(grep "^$3|" "$DB_FILE")
    [ -z "$INFO" ] && echo "Package not found" && exit 1
    IFS="|" read -r NAME CATEGORY TYPE STATUS <<< "$INFO"

    if [ "$TYPE" = "native" ]; then
        pkg uninstall "$NAME" -y
    elif [ "$TYPE" = "plugin" ]; then
        echo "Plugin removal coming soon"
    else
        echo "Manual removal required"
    fi
    exit 0
    ;;

check)
    bash "$BASE_DIR/scripts/package/package_manager.sh" "$BASE_DIR"
    exit 0
    ;;

esac

fi

while true
do
    clear

    soluk_header "SolukOS Manager"

    choice=$(soluk_menu "SolukOS" \
        "System Info" \
        "Backup Manager" \
        "Settings" \
        "About" \
        "Update SolukOS" \
        "Log Manager" \
        "Plugin Manager" \
        "Package Manager" \
        "Exit")

    case "$choice" in
        "System Info")     bash "$BASE_DIR/scripts/info.sh" "$BASE_DIR" ;;
        "Backup Manager")  bash "$BASE_DIR/scripts/backup_manager.sh" "$BASE_DIR" ;;
        "Settings")        bash "$BASE_DIR/scripts/settings.sh" "$BASE_DIR" ;;
        "About")           bash "$BASE_DIR/scripts/about.sh" "$BASE_DIR" ;;
        "Update SolukOS")  bash "$BASE_DIR/scripts/update.sh" "$BASE_DIR" ;;
        "Log Manager")     bash "$BASE_DIR/scripts/log_manager.sh" "$BASE_DIR" ;;
        "Plugin Manager")  bash "$BASE_DIR/scripts/plugin_manager.sh" "$BASE_DIR" ;;
        "Package Manager") bash "$BASE_DIR/scripts/package/package_manager.sh" "$BASE_DIR" ;;
        "Exit"|"")         echo "Goodbye."; exit 0 ;;
        *)                 echo "Invalid option." ;;
    esac

    echo ""
    read -p "Press Enter to continue..."
done
