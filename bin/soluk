#!/data/data/com.termux/files/usr/bin/bash

BASE_DIR="$(cat ~/.solukos/install_path 2>/dev/null)"

if [ -z "$BASE_DIR" ]; then
    echo "SolukOS installation path not found."
    exit 1
fi

source "$BASE_DIR/scripts/lib/ui.sh"

if [ "$1" = "version" ]; then
    clear
    soluk_header "SolukOS Version"

    VERSION_STR=$(cat "$BASE_DIR/VERSION" 2>/dev/null)
    [ -z "$VERSION_STR" ] && VERSION_STR="unknown"

    echo -e "  ${SOLUK_BOLD}${SOLUK_YELLOW}v${VERSION_STR}${SOLUK_RESET}"
    echo ""
    exit 0
fi

if [ "$1" = "help" ]; then
    clear
    soluk_header "SolukOS Help"

    echo -e "${SOLUK_BOLD}${SOLUK_CYAN}Usage${SOLUK_RESET}"
    echo -e "  soluk                     Open the interactive Manager menu"
    echo ""
    echo -e "${SOLUK_BOLD}${SOLUK_CYAN}System${SOLUK_RESET}"
    echo -e "  soluk version             Show installed version"
    echo -e "  soluk doctor              Check installation health"
    echo -e "  soluk fetch               Show system summary"
    echo -e "  soluk reload              Reload the shell"
    echo -e "  soluk help                Show this help message"
    echo ""
    echo -e "${SOLUK_BOLD}${SOLUK_CYAN}Packages${SOLUK_RESET}"
    echo -e "  soluk pkg list            List all known packages"
    echo -e "  soluk pkg search <name>   Search the package database"
    echo -e "  soluk pkg info <name>     Show package details"
    echo -e "  soluk pkg install <name>  Install a package"
    echo -e "  soluk pkg remove <name>   Remove a package"
    echo -e "  soluk pkg check           Open the Package Manager menu"
    echo ""
    echo -e "${SOLUK_BOLD}${SOLUK_CYAN}Shell tools${SOLUK_RESET} ${SOLUK_GRAY}(built into your terminal)${SOLUK_RESET}"
    echo -e "  z <folder>                Jump to a frequent directory (zoxide)"
    echo -e "  ll / lt                   List files with icons (eza)"
    echo -e "  cat <file>                Preview a file, highlighted (bat)"
    echo -e "  Ctrl+R / Ctrl+T / Alt+C   Search history / files / cd (fzf)"
    echo ""
    exit 0
fi

if [ "$1" = "doctor" ]; then
    clear
    soluk_header "SolukOS Doctor"

    [ -d "$BASE_DIR" ] && soluk_ok "SolukOS directory" || soluk_fail "SolukOS directory"
    [ -f "$BASE_DIR/packages/database.txt" ] && soluk_ok "Package database" || soluk_fail "Package database"
    [ -f "$BASE_DIR/scripts/package/package_manager.sh" ] && soluk_ok "Package Manager" || soluk_fail "Package Manager"
    [ -f "$BASE_DIR/scripts/lib/ui.sh" ] && soluk_ok "UI library" || soluk_fail "UI library"
    command -v fzf >/dev/null 2>&1 && soluk_ok "fzf (modern menu)" || soluk_fail "fzf (modern menu) - pkg install fzf"
    command -v zoxide >/dev/null 2>&1 && soluk_ok "zoxide" || soluk_fail "zoxide - pkg install zoxide"
    command -v bat >/dev/null 2>&1 && soluk_ok "bat" || soluk_fail "bat - pkg install bat"
    command -v eza >/dev/null 2>&1 && soluk_ok "eza" || soluk_fail "eza - pkg install eza"
    [ -f ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh ] && soluk_ok "zsh-autosuggestions" || soluk_fail "zsh-autosuggestions - soluk update ile kurulur"
    [ -f ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && soluk_ok "zsh-syntax-highlighting" || soluk_fail "zsh-syntax-highlighting - soluk update ile kurulur"
    echo ""
    exit 0
fi

if [ "$1" = "reload" ]; then
    exec zsh
fi

if [ "$1" = "fetch" ]; then
    clear
    soluk_banner "$BASE_DIR"

    VERSION_STR=$(cat "$BASE_DIR/VERSION" 2>/dev/null)
    [ -z "$VERSION_STR" ] && VERSION_STR="unknown"

    UPTIME_STR=$(awk '{printf "%dh %dm", ($1/3600), ((($1)%3600)/60)}' /proc/uptime 2>/dev/null)
    [ -z "$UPTIME_STR" ] && UPTIME_STR="unknown"

    STORAGE_STR=$(df -h "$HOME" 2>/dev/null | awk 'NR==2{print $3" / "$2" used"}')
    [ -z "$STORAGE_STR" ] && STORAGE_STR="unknown"

    PKG_COUNT=$(grep -c '|' "$BASE_DIR/packages/database.txt" 2>/dev/null)
    [ -z "$PKG_COUNT" ] && PKG_COUNT=0

    soluk_row "OS"       "SolukOS v$VERSION_STR"
    soluk_row "Host"     "Termux (Android)"
    soluk_row "Kernel"   "$(uname -r 2>/dev/null)"
    soluk_row "Shell"    "${SHELL##*/}"
    soluk_row "Uptime"   "$UPTIME_STR"
    soluk_row "Storage"  "$STORAGE_STR"
    soluk_row "Packages" "$PKG_COUNT (soluk db)"
    echo ""
    exit 0
fi

if [ "$1" = "pkg" ]; then

DB_FILE="$BASE_DIR/packages/database.txt"

case "$2" in

list)
    cat "$DB_FILE"
    exit 0
    ;;

search)
    grep -i "$3" "$DB_FILE"
    exit 0
    ;;

info)
    INFO=$(grep "^$3|" "$DB_FILE")
    [ -z "$INFO" ] && echo "Package not found" && exit 1
    IFS="|" read -r NAME CATEGORY TYPE STATUS <<< "$INFO"
    echo "Name: $NAME"
    echo "Category: $CATEGORY"
    echo "Type: $TYPE"
    echo "Status: $STATUS"
    exit 0
    ;;

install)
    INFO=$(grep "^$3|" "$DB_FILE")
    [ -z "$INFO" ] && echo "Package not found" && exit 1
    IFS="|" read -r NAME CATEGORY TYPE STATUS <<< "$INFO"

    if [ "$TYPE" = "native" ]; then
        pkg install "$NAME" -y
    elif [ "$TYPE" = "plugin" ]; then
        echo "Plugin installer coming soon"
    else
        echo "Manual install required"
    fi
    exit 0
    ;;

remove)
    INFO=$(grep "^$3|" "$DB_FILE")
    [ -z "$INFO" ] && echo "Package not found" && exit 1
    IFS="|" read -r NAME CATEGORY TYPE STATUS <<< "$INFO"

    if [ "$TYPE" = "native" ]; then
        pkg uninstall "$NAME" -y
    elif [ "$TYPE" = "plugin" ]; then
        echo "Plugin removal coming soon"
    else
        echo "Manual removal required"
    fi
    exit 0
    ;;

check)
    bash "$BASE_DIR/scripts/package/package_manager.sh" "$BASE_DIR"
    exit 0
    ;;

*)
    echo -e "${SOLUK_RED}[✗] Unknown pkg command:${SOLUK_RESET} $2"
    echo "Usage: soluk pkg {list|search|info|install|remove|check} ..."
    exit 1
    ;;

esac

fi

if [ -n "$1" ]; then
    echo -e "${SOLUK_RED}[✗] Unknown command:${SOLUK_RESET} $1"
    echo "Run 'soluk help' to see available commands."
    exit 1
fi

while true
do
    clear

    soluk_header "SolukOS Manager"

    choice=$(soluk_menu "SolukOS" \
        "System Info" \
        "Backup Manager" \
        "Settings" \
        "About" \
        "Update SolukOS" \
        "Log Manager" \
        "Plugin Manager" \
        "Package Manager" \
        "Exit")

    case "$choice" in
        "System Info")     bash "$BASE_DIR/scripts/info.sh" "$BASE_DIR" ;;
        "Backup Manager")  bash "$BASE_DIR/scripts/backup_manager.sh" "$BASE_DIR" ;;
        "Settings")        bash "$BASE_DIR/scripts/settings.sh" "$BASE_DIR" ;;
        "About")           bash "$BASE_DIR/scripts/about.sh" "$BASE_DIR" ;;
        "Update SolukOS")  bash "$BASE_DIR/scripts/update.sh" "$BASE_DIR" ;;
        "Log Manager")     bash "$BASE_DIR/scripts/log_manager.sh" "$BASE_DIR" ;;
        "Plugin Manager")  bash "$BASE_DIR/scripts/plugin_manager.sh" "$BASE_DIR" ;;
        "Package Manager") bash "$BASE_DIR/scripts/package/package_manager.sh" "$BASE_DIR" ;;
        "Exit"|"")
            clear
            soluk_banner "$BASE_DIR"
            echo ""
            echo -e "${SOLUK_GRAY}[ SolukOS ] Menu closed.${SOLUK_RESET}"
            echo ""
            exit 0
            ;;
        *)
            echo "Invalid option."
            ;;
    esac

    echo ""
    read -p "Press Enter to continue..."
done
