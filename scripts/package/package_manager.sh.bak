#!/data/data/com.termux/files/usr/bin/bash

BASE_DIR="$HOME/SolukOS"
DB="$BASE_DIR/packages/database.txt"

while true
do
clear

echo "=== SolukOS Package Manager ==="
echo "[1] List"
echo "[2] Check"
echo "[3] Back"

read -p "Choice: " choice

case "$choice" in

1)
cat "$DB"
;;

2)
while IFS="|" read -r NAME CATEGORY TYPE STATUS
do
command -v "$NAME" >/dev/null 2>&1 &&
echo "[✓] $NAME" ||
echo "[ ] $NAME"
done < "$DB"
;;

3)
exit 0
;;

esac

read -p "Press Enter..."
done
